# ========================================
# OPEN JAM — CONFIGURATION
# ========================================

# YouTube Data API v3 Key — the ONLY key you need
# Get it FREE at: https://console.cloud.google.com
#   1. Create a project
#   2. Enable "YouTube Data API v3"
#   3. Create an API key
# Free quota: 10,000 units/day (each search = 100 units → 100 searches/day free)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Track search uses Apple's iTunes API — NO KEY NEEDED, works out of the box!

# Security Key (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=generate-random-secure-key-here

# Database
DATABASE_URL=sqlite:///./openjam.db
